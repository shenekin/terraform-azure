# Basic Configuration
resource_group_name = "my-aks-rg"
location            = "eastasia"
environment         = "production"
cluster_name        = "my-production-aks"
dns_prefix          = "prod-aks"

# Node Configuration
node_count          = 3
vm_size             = "Standard_D4s_v3"
enable_auto_scaling = true
min_node_count      = 2
max_node_count      = 6

# Network Configuration
vnet_address_space     = ["10.0.0.0/16"]
subnet_address_prefixes = ["10.0.1.0/24"]
network_plugin         = "azure"
max_pods               = 50

# User Node Pool
enable_user_node_pool      = true
user_node_pool_vm_size     = "Standard_D4s_v3"
user_node_pool_node_count  = 3
user_node_pool_auto_scaling = true
user_node_pool_min_count   = 2
user_node_pool_max_count   = 8

# Tags
tags = {
  Environment = "production"
  ManagedBy   = "Terraform"
  Project     = "MyProject"
  CostCenter  = "IT"
}